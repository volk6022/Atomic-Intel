# --- Internal Auth ---
# Bootstrap/admin key: always resolves to a synthetic Principal without
# touching Postgres (src/api/auth.py). Real tenants + their own keys are
# issued via the TG admin bot (src/bot/) and live in the tables below.
API_KEY=default_internal_key
REDIS_URL=redis://localhost:6379
PORT=8000

# --- Control-plane: tenants/keys (Postgres) ---
# In docker-compose, DATABASE_URL's host/creds are derived from POSTGRES_*
# automatically; set it explicitly when running the API/worker/bot outside
# compose (e.g. against a local Postgres).
DATABASE_URL=postgresql+asyncpg://atomic:change_me@localhost:5432/atomic_intel
POSTGRES_USER=atomic
POSTGRES_PASSWORD=change_me
POSTGRES_DB=atomic_intel
# AUTH_CACHE_TTL_SECONDS=30.0
# DEFAULT_TENANT_QUOTA_PER_HOUR=500
# DEFAULT_TENANT_CONCURRENT_RESEARCH=2

# --- TG admin bot (src/bot/) ---
# Bot token from @BotFather. CSV of numeric Telegram user ids allowed to run
# bot commands (issue/revoke keys, set quota, bind BYO-LLM, usage).
BOT_TOKEN=
ADMIN_TG_IDS=

# --- Extraction Settings (e.g., Jina Reader LM) ---
EXTRACTION_API_BASE=http://localhost:1234/v1
EXTRACTION_API_KEY=lm-studio
EXTRACTION_MODEL_NAME=jinaai.readerlm-v2

# --- Orchestration Settings (reasoning/navigation) ---
ORCHESTRATION_API_BASE=https://api.openai.com/v1
ORCHESTRATION_API_KEY=sk-...
ORCHESTRATION_MODEL_NAME=gpt-4o

# --- Scraper Settings ---
BROWSER_TIMEOUT=30000
SESSION_INACTIVITY_TIMEOUT=600
MAX_CONCURRENT_RESEARCH_TASKS=5

# --- Rate Limiting (optional) ---
# Per-tenant hourly quota now lives in Postgres (tenants.quota_per_hour, set
# via the TG bot's /setquota). RATE_LIMIT_YANDEX_PER_HOUR is no longer read
# by the inbound rate-limit middleware (bug C-01 fix) — kept as a reserved
# knob for a future outbound per-target throttler.
# RATE_LIMIT_YANDEX_PER_HOUR=30
# RATE_LIMIT_DEFAULT_PER_HOUR=1000

# --- Research Agent (flat-loop) — all optional, defaults match production v2.1 ---
# RESEARCH_COMPACT_TRIGGER_TOKENS=50000
# RESEARCH_MAX_COMPACTIONS=3
# RESEARCH_SOFT_ELIDE_AFTER_TURNS=4
# RESEARCH_REFRASER_EVERY_N_SERPS=15
# RESEARCH_DOMAIN_FAIL_THRESHOLD=3
# RESEARCH_LLM_TIMEOUT_S=180.0
# RESEARCH_SCRAPE_BUDGET_CHARS=3500
# RESEARCH_CRITIC_PASS_SCORE=8.5
# RESEARCH_MAX_SUBMIT_REJECTS=2
# RESEARCH_DEFAULT_LANGUAGE=ru
# RESEARCH_DEFAULT_SERP_K=6
# RESEARCH_DOMAINS_NEVER_BLOCK=yandex.ru,2gis.ru,hh.ru,vk.com,t.me
# RESEARCH_PROMPTS_PATH=src/actions/research/research_agent_prompts.yaml

# --- M3: LLM-availability gate + durable research store — all optional ---
# How often the worker's LLM-health supervisor re-probes endpoints that have
# tasks parked in `queued_waiting_llm`.
# LLM_HEALTH_POLL_INTERVAL_SECONDS=30.0
# Per-probe timeout — a hung LLM must not block the poller.
# LLM_HEALTH_PING_TIMEOUT_SECONDS=5.0
# Pre-flight checks (one per task, before the agent runs) share one probe per
# endpoint within this window instead of hitting the LLM once per task.
# LLM_HEALTH_PROBE_CACHE_SECONDS=15.0
# Durable disk fallback for completed ResearchReports (survives the 24h Redis
# TTL). In docker-compose this is set to /data/research, a named volume
# shared by the `api` and `worker` services.
# RESEARCH_STORE_DIR=data/research
